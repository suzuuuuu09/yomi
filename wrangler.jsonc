{
  "$schema": "https://developers.cloudflare.com/workers/wrangler/schema/v2.0.0/wrangler.schema.json",
  "name": "yomi",
  "compatibility_date": "2026-02-28",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".vercel/output/static",
